<?xml version="1.0" encoding="utf-8"?>
<!--
  Pre-Android-12 launch window background. The Android 12+ splash uses the
  attributes in [values/styles.xml] (windowSplashScreenBackground +
  windowSplashScreenAnimatedIcon) and ignores this drawable entirely.

  Layer 1: brand background colour (light / dark resolved via day-night
           resources — see values-night/colors.xml).
  Layer 2: centred Tales & Tech logo (transparent foreground PNG already
           generated by flutter_launcher_icons at every density). Rendered
           at its intrinsic 108-dp size to match the Android 12+ splash
           icon look.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/launch_background" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/ic_launcher_foreground" />
    </item>
</layer-list>
