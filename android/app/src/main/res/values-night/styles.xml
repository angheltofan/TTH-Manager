<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark-mode variant of LaunchTheme. `@color/launch_background`
         resolves to `#070B1F` (values-night/colors.xml) so Android 12+
         shows the dark navy splash matching the Flutter dark-theme
         scaffoldBackgroundColor. The launch drawable, the Android 12+
         system splash and Flutter's `_BrandedSplash` are all on the
         same colour — no double-splash, no colour jump. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/launch_background</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="31">@color/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/launch_background</item>
    </style>
</resources>
