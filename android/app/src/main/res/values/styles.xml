<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Theme applied to the Android Window while the process is starting
         when the OS's Dark Mode setting is off.

         Android ≤ 11 paints `windowBackground` (the layer-list drawable
         with our brand colour + centred logo). Android 12+ ignores it and
         instead reads the three `windowSplashScreen*` attributes below,
         showing the same brand colour + the launcher icon foreground at
         the standard Android 12+ splash-icon size.

         The native splash → NormalTheme swap is wired by Flutter via the
         `io.flutter.embedding.android.NormalTheme` meta-data on the
         MainActivity in AndroidManifest.xml — no framework `postSplash-
         ScreenTheme` attribute exists, that attribute belongs to the
         AndroidX `core-splashscreen` compat library which Flutter
         already replaces. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/launch_background</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="31">@color/launch_background</item>
    </style>
    <!-- Theme applied to the Android Window as soon as the process has
         started. This theme determines the colour of the Android Window
         while the Flutter UI initialises, as well as behind the Flutter UI
         while it is running.

         Set to the same brand background as the launch drawable so the
         transition from native splash → NormalTheme → Flutter splash is
         a single uninterrupted brand surface. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/launch_background</item>
    </style>
</resources>
